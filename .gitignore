# --- ipsum-specific ---
# Private strategy / startup / moat notes — never commit
_private/
# Large source PDFs of papers — keep notes, not the binaries
research/papers/
*.pdf
# Datasets / pulled CI history — keep scripts + README, ignore the actual data
data/rtptorrent/
data/**/*.csv
data/**/*.parquet
data/**/*.db
data/**/*.zip
*.parquet
*.db

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version

# --- Frontend (Node/Vite) ---
frontend/node_modules/
frontend/dist/
frontend/.vite/
# data is copied/symlinked in for dev — don't commit it
frontend/public/runs/
npm-debug.log*

# --- Backend run artifacts (regenerable) ---
experiments/runs/

# --- Tooling ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.coverage
htmlcov/

# --- OS / editor ---
.DS_Store
.idea/
.vscode/
